{% extends 'base.html.twig' %}

{% block title %}Accueil
{% endblock %}

{% block body %}
	<style></style>
	{% include 'component/navBar.html.twig'  %}
	<section class="min-h-screen flex items-center justify-center text-center p-2 flex flex-col">
		<div class="flex justify-end w-full gap-4 xs:max-w-xl md:max-w-4xl lg:max-w-7xl mb-4">
			<a href="{{ path('app_gestionnaire_add') }}" class="text-white cursor-pointer bg-slate-800 hover:bg-slate-700 p-2 rounded-lg">
				AJOUTER
			</a>
		</div>
		<div class="bg-slate-800 p-6 rounded-lg text-white w-full xs:max-w-xl md:max-w-4xl lg:max-w-7xl overflow-x-auto">
			<table class="w-full text-left border-collapse">
				<thead>
					<tr class="border-b border-slate-600">
						<th class="px-4 py-2">URL + Site</th>
						<th class="px-4 py-2">Identifiant</th>
						<th class="px-4 py-2">Mot de passe</th>
						<th class="px-4 py-2 text-center">Modifier</th>
						<th class="px-4 py-2 text-center">Supprimer</th>
					</tr>
				</thead>
				<tbody>
					{% for data in datas %}
						<tr class="border-b border-slate-700 hover:bg-slate-900">
							<td class="px-4 py-2 italic">
								<a target="_blank" href="{{ data.url }}">{{ data.site }}</a>
							</td>
							<td class="px-4 py-2">
								{% if data.identifier|length > 15 %}
									<p class="">{{ data.identifier|slice(0,15)}}...</p>
								{% else %}
									<p class="">{{ data.identifier }}</p>
								{% endif %}
							</td>
							<td class="copiable px-4 py-2 password-hidden hover:text-red-600" data-value="{{ data.password }}">
								{% if  data.password|length > 15 %}
									<p class="">{{ data.password|slice(0,15)}}...</p>
								{% else %}
									<p class="">{{ data.password }}</p>
								{% endif %}
							</td>
							<td class="px-4 py-2 text-center cursor-pointer hover:text-blue-600">
								<a href="{{ path('app_gestionnaire_update', { uuid: data.uuid }) }}">
									<i class="fa-solid fa-file-pen"></i>
								</a>
							</td>
							<td class="px-4 py-2 text-center cursor-pointer hover:text-red-600">
								<form method="post" action="{{ path('app_gestionnaire_delete', { uuid: data.uuid }) }}" onsubmit="return confirm('Confirmer la suppression ?');">
									<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ data.uuid) }}">
									<button class="btn btn-link p-0">
										<i class="fa fa-trash"></i>
									</button>
								</form>
							</td>
						</tr>
					{% else %}
						<tr class="border-b border-slate-700 hover:bg-slate-900">
							<td class="text-center">Aucun</td>
							<td class="text-center">mot</td>
							<td class="text-center">de</td>
							<td class="text-center">passe</td>
							<td class="text-center">enregistrer</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</section>

{% endblock %}
