{% if files is defined and files|length %}
    <div class="bg-slate-800 p-5 text-white">
        <form
            method="POST"
            action="{{ path('app_test_uploads') }}"
            enctype="multipart/form-data"
            class="flex items-center justify-between gap-5"
        >
            <div class="flex items-center gap-4">
                <label for="file-select" class="font-medium">
                    Liste des images uploadées
                </label>

                <select
                    id="file-select"
                    name="name"
                    class="text-black rounded px-2 py-1"
                    required
                >
                    <option value="" disabled selected>
                        Sélectionner une image
                    </option>

                    {% for file in files %}
                        <option value="{{ file }}">{{ file }}</option>
                    {% endfor %}
                </select>
            </div>

            <button
                type="submit"
                class="bg-blue-600 text-white rounded px-4 py-2 hover:bg-blue-700 transition"
            >
                Uploads
            </button>
        </form>
    </div>
{% else %}
    <div class="bg-slate-800 p-5 text-white">
        <p>Aucune image uploadée</p>
    </div>
{% endif %}
