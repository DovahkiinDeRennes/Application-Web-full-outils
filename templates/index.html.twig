{% extends 'base.html.twig' %}

{% block title %}Accueil
{% endblock %}

{% block body %}


	<section class="min-h-screen flex items-center">
		<div class="p-6 rounded-lg text-white w-full max-w-4xl">
			<div class="flex flex-col md:flex-row gap-4 min-w-0">

				<nav class="bg-slate-800 rounded-md p-4 w-full overflow-hidden">
					<h1 class="p-2">MENU</h1>

					<ul class="flex gap-4 overflow-x-auto pb-4 whitespace-nowrap">
						{% if app.user %}
							<li>
								<a href="/logout" class="bg-slate-700 hover:bg-slate-600 px-4 py-2 rounded-full cursor-pointer inline-flex items-center">Deconnexion</a>
							</li>
						{% else %}
							<li>
								<a href="/login" class="bg-slate-700 hover:bg-slate-600 px-4 py-2 rounded-full cursor-pointer inline-flex items-center">Connexion</a>
							</li>
						{% endif %}
						<li>
							<a href="/gestionnaire" class="bg-slate-700 hover:bg-slate-600 px-4 py-2 rounded-full cursor-pointer inline-flex items-center">Gestionnaire de mot de passe</a>
						</li>
						<li>
							<a href="/gestionnaire/add-master-key" class="bg-slate-700 hover:bg-slate-600 px-4 py-2 rounded-full cursor-pointer inline-flex items-center">Création Master Key</a>
						</li>

						<li>
							<a href="/converter" class="bg-slate-700 hover:bg-slate-600 px-4 py-2 rounded-full cursor-pointer inline-flex items-center">Convertir une Image</a>
						</li>
					</ul>
				</nav>

				<div class="bg-slate-800 rounded-md p-4">
					<h2>Explication</h2>
					<p class="text-slate-500">
						Application utilitaire pour but d'ameliorer mon quotidien,
						<br>
						avec l'ajout d'un convertisseur d'image,<br>
						l'ajout prochainement d'un gestionnaire de
						<br>
						mot de passe 100% locale etc...
					</p>
				</div>

			</div>
		</div>
	</section>
{% endblock %}


